    {
      "id": "p1",
      "de": "Die 2 Kupplungstreibscheiben und 3 Kupplungsscheiben aus Kupplungszwischenring herausnehmen.",
      "en-GB": "Take the 2 clutch drive discs and 3 clutch discs out of the clutch intermediate ring.",
      "es-ES": "Extraer los 2 discos motrices del embrague y los 3 discos de embrague del anillo intermedio del embrague."
    },
    {
      "id": "p2",
      "de": "Den Abstandsring vor dem hinteren Kugellager ausziehen.",
      "en-GB": "Pull out the spacer ring in front of the rear ball bearing.",
      "es-ES": "Extraer el anillo distanciador situado delante del cojinete de bolas trasero."
    }
