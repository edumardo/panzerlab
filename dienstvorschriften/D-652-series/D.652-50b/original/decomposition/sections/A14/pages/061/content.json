    {
      "id": "p1",
      "de": "Mit 14-SW- und 17-SW-Maulschlüssel die Schrauben aus dem Gelenkwellentunnel und dem Kupplungsvorbau ausschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Splinte aus den Kronenmuttern ziehen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Mit zwei 17-SW-Maulschlüsseln die Gelenkwelle von der Kupplungswelle (1) abschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Vergasergestänge (2) aus den Kugelgelenken drücken.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Den Verbindungsbolzen (3) aus dem Kupplungsgestänge ziehen.",
      "en-GB": null,
      "es-ES": null
    }
