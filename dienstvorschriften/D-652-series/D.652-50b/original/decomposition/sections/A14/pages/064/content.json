  "paragraphs": [
    {
      "id": "p1",
      "de": "Mit Zange die Haltefedern so weit herausziehen, bis sich die Scheiben der Haltefedern seitlich entfernen lassen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Kupplungsdruckplatte abheben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Mit der Vorrichtung, Zeichnung 3 D 652/50 a, die Kupplungsdruckfeder entspannen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Sicherungsdraht aus den drei Befestigungsschrauben des Ausrücklagers ziehen und diese mit 14-SW-Maulschlüssel ausschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Vorrichtung auseinanderschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p6",
      "de": "Beachten: Bei festsitzendem Ausrücklager dieses mit Hebel von den drei Zapfen der Schiebebolzen abdrücken.",
      "en-GB": null,
      "es-ES": null
    }
  ],
