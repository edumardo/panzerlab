  "paragraphs": [
    {
      "id": "p1",
      "de": "Das Triebrad mit Holz unterbauen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Mit Winde die Panzerwanne so anheben, daß das Triebrad leicht auf dem Holzunterbau ruht.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Die Blechsicherungen der Befestigungsschrauben des Seitenvorgeleges geradebiegen, Bild 55.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Mit 22-SW-Ringschlüssel die entsicherten Muttern abschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Beachten: Die auf Bild 55 bezeichneten drei Muttern nicht entfernen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p6",
      "de": "Gelenkwelle ausbauen, Randnummer 1, Ausbau der Gelenkwelle zwischen Lenkgetriebe und Lenkbremse, Bild 1 bis 8.",
      "en-GB": null,
      "es-ES": null
    }
