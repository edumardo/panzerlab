    {"id": "p1", "de": "Kappe (4) über die Ritzelwelle führen.", "en-GB": null, "es-ES": null},
    {"id": "p2", "de": "Die Mutter (2) auf die Spindel (1) schrauben.", "en-GB": null, "es-ES": null},
    {"id": "p3", "de": "Zwischenring (3) auf den Bund der Mutter legen.", "en-GB": null, "es-ES": null},
    {"id": "p4", "de": "Zugspindel an den oberen Vierkant in die Ritzelwelle schrauben (Zeichnung 4)¹).", "en-GB": null, "es-ES": null},
    {"id": "p5", "de": "Die Ritzelwelle in das Gehäuse des Seitenvorgeleges führen.", "en-GB": null, "es-ES": null},
    {"id": "p6", "de": "Druckplatte auflegen und diese mit den Abstandsrohren und Bolzen verschrauben.", "en-GB": null, "es-ES": null},
