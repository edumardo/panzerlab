  "paragraphs": [
    {
      "id": "p1",
      "de": "Kupplungsdeckel mit Kupplungsdruckplatte an den Kupplungsring halten und diese mit zwei gegenüberliegenden Schrauben so einschrauben, daß sich die Kupplungstreibscheiben mit Hilfe der Kupplungswelle drehen lassen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Die Kupplungswelle mit den Kupplungstreibscheiben so weit herumdrehen, bis die Nuten der drei Kupplungstreibscheiben übereinanderstehen und sich die Kupplungswelle ganz einführen läßt.",
      "en-GB": null,
      "es-ES": null
    }
