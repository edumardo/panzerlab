  "paragraphs": [
    {
      "id": "p1",
      "de": "Mit den acht Innensechskantschrauben die Kupplungsplatte an das Schwungrad schrauben. Die Innensechskantschrauben durch Verbohren und Verstiften in den Sechskanten sichern.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Das Pendelkugellager vor dem Einbau mit Heißlager- oder Abschmierfett einfetten.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Den Lagerdeckel mit dem hinteren Pendelkugellager an das Schwungrad bringen und mit 10-SW-Steckschlüssel die sechs Schrauben einschrauben.",
      "en-GB": null,
      "es-ES": null
    }
  ],
