  "paragraphs": [
    {
      "id": "p1",
      "de": "Beim Anschrauben eines neuen Schwungrades muß das Schwungrad an dem Motor eingestellt werden.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Kurbelwelle so weit herumdrehen, bis sich die Ventile des ersten Zylinders auf der Wasserpumpenseite überschneiden.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Schwungrad mit der Einstellmarke „1 und 6 oben“ an die Kurbelwelle schrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Mit den zwölf Vierkantschrauben das Schwungrad an die Kurbelwelle schrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Die beim Ausbau eingeschlagenen Körnerzeichen beachten.",
      "en-GB": null,
      "es-ES": null
    }
  ],
