  "paragraphs": [
    {
      "id": "p1",
      "de": "Die Kupplungswelle ganz in die Kupplung einschieben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Mit Verstellschlüssel die Kupplung leicht auslösen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Beachten: Die Kupplung nur bei eingeschobener Kupplungswelle auslösen, da sonst die Kupplungstreibscheiben aus der Mitte rutschen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Sicherungsbleche auf die Stiftschrauben der vorderen Lagerbefestigung legen und mit 17-SW-Steckschlüssel die Muttern festschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Die Muttern durch Umbiegen der Blechsicherungen sichern.",
      "en-GB": null,
      "es-ES": null
    }
  ],
