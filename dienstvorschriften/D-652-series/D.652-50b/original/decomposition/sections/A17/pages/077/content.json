  "paragraphs": [
    {
      "id": "p1",
      "de": "Einen Dorn in Stärke der Nietköpfe in den Schraubstock spannen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Zu beiden Seiten der Kupplungsscheibe einen neuen Kupplungsbelag mit den Versenkseiten nach außen legen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Von unten durch den Belag der Kupplungsscheibe und den oberen Belag eine Niete einführen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Den unteren Nietkopf auf den Dorn im Schraubstock aufliegen lassen und diesen mit Hammer und Dorn vernieten.",
      "en-GB": null,
      "es-ES": null
    }
  ],
