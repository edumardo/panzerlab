  "paragraphs": [
    {
      "id": "p1",
      "de": "Das schwächere Gewinde des Zwischenstückes (Zeichnung 5)¹). in das Gewinde der Ritzelwelle schrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Die Spindel der Drehstabfederausziehvorrichtung III DB 101 auf das Gewinde des Zwischenstückes schrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Scheibe (Zeichnung 5)¹) in die Ausdrehung der Bremstrommelnabe legen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Glocke III DB 101 über die Spindel führen und Mutter aufsetzen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Mit 32-SW-Maulschlüssel die Ritzelwelle mit der Bremstrommelnabe zusammenziehen und die Gelenkwelle einbauen, Randnummer 2, Einbau der Gelenkwelle zwischen Lenkgetriebe und Lenkbremse, Bild 9 bis 10.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p6",
      "de": "¹) Siehe im Anhang.",
      "en-GB": null,
      "es-ES": null
    }
