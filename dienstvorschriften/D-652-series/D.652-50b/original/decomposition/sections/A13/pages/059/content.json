  "paragraphs": [
    {
      "id": "p1",
      "de": "Das Seitenvorgelege mit Hammer und Holzklotz an die Panzerwanne schlagen. (Darauf achten, daß die Bremstrommelwelle nicht aus dem Lager gleitet.)",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Sicherungsbleche auf den Befestigungsbolzen legen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Mit 22-SW-Steck- oder -Ringschlüssel das Seitenvorgelege mit der Panzerwanne verschrauben, Bild 55.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Die Muttern durch Umbiegen der Sicherungsbleche sichern.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "Bis zur oberen Einfüllschraube Öl in das Seitenvorgelege füllen, Bild 54.",
      "en-GB": null,
      "es-ES": null
    }
  ],
