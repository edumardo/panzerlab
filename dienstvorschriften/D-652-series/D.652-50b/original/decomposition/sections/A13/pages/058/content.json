    {
      "id": "p1",
      "de": "Einen Gummi-Dichtring (1), auf die Abstandsbuchse (2) und einen weiteren Gummi-Dichtring (3) auf die Nabe der Ritzelwelle schieben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Das Seitenvorgelege mit Brechstange aufrichten und die Ritzelwelle auf gleiche Höhe mit der Bremstrommelwelle heben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Die Bremstrommel so weit herumdrehen, bis die Nuten der Ritzel- und Bremstrommelwelle ineinander passen.",
      "en-GB": null,
      "es-ES": null
    }
