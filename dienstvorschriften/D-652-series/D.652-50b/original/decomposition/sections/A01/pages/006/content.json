  "paragraphs": [
    {
      "id": "p1",
      "de": "Die Paßschrauben durch Hammerschlag auf Kronenmutter lösen dann Mutter und Schraube von Hand entfernen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Beim Entfernen der Paßschrauben an der Bremstrommelseite Bremstrommel so weit herumdrehen, bis sich die jeweilig zu entfernende Paßschraube an der Ausfräsungsstelle (♦) der Nabe befindet.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Beachten: Die Paßschrauben dürfen nur an der Ausfräsungsstelle gelöst und entfernt werden.",
      "en-GB": null,
      "es-ES": null
    }
