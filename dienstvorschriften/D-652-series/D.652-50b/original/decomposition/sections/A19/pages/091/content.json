  "paragraphs": [
    {
      "id": "p1",
      "de": "An der rechten und linken Getriebeseite die Gelenkwellenschutzbleche entfernen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Die Gelenkwellen ausbauen, Randnummer 1, Ausbau der Gelenkwelle zwischen Lenkgetriebe und Lenkbremse, Bild 1 bis 8.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Mit 17-SW-Steckschlüssel an der vorderen rechten und linken Getriebeseite die Befestigungsschrauben der Getriebeaufhängung herausschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Drahtsicherung herausziehen und mit 24-SW-Maulschlüssel die Schrauben der hydraulischen Rohrleitung abschrauben.",
      "en-GB": null,
      "es-ES": null
    }
