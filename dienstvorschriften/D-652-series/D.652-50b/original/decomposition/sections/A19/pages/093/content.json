    {
      "id": "p1",
      "de": "Splinte herausziehen und mit zwei 17-SW-Maulschlüsseln die beiden hinteren Getriebebefestigungsschrauben abschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "Am Getriebe die Befestigungsschellen der elektrischen Zuleitung zum Schaltbrett lösen. Überwurfmuttern der Geschwindigkeitsmesser- und Drehzahlmesserantriebswellen abschrauben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Schaltbrett vorne auf den Panzer legen.",
      "en-GB": null,
      "es-ES": null
    }
