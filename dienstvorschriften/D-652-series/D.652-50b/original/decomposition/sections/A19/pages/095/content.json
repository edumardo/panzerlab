  "paragraphs": [
    {
      "id": "p1",
      "de": "Die vorderen Greifer der Ausbauvorrichtung (Zeichnung 6 und 7)¹) unter das Verbindungsrohr des Lenkgetriebes führen.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p2",
      "de": "An der hinteren Getriebeseite den Vorrichtungshaken in die Hohlwelle stecken.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p3",
      "de": "Das Getriebe mit Kette an den Haken und der Vorrichtung so aufhängen, daß das hintere Ende etwas höher hängt.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p4",
      "de": "Das Getriebe ausheben.",
      "en-GB": null,
      "es-ES": null
    },
    {
      "id": "p5",
      "de": "¹) Siehe im Anhang.",
      "en-GB": null,
      "es-ES": null
    }
  ],
