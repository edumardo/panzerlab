{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "D 652/50a source page manifest",
  "type": "object",
  "required": ["page", "section", "pdf_page", "side", "source_scan", "content", "source_scan_status", "transcription_status", "translation_en_status", "translation_es_status", "figures"],
  "properties": {
    "page": {"type": "integer", "minimum": 1, "maximum": 101},
    "section": {"type": "string"},
    "pdf_page": {"type": "integer", "minimum": 2, "maximum": 52},
    "side": {"enum": ["left", "right", "single"]},
    "source_scan": {"type": "string"},
    "content": {"type": "string", "const": "content.json"},
    "source_scan_status": {"enum": ["extracted_clean", "validated"]},
    "transcription_status": {"enum": ["pending", "draft", "validated"]},
    "translation_en_status": {"enum": ["pending", "draft", "validated"]},
    "translation_es_status": {"enum": ["pending", "draft", "validated"]},
    "figures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number"],
        "properties": {
          "number": {"type": ["integer", "null"]},
          "path": {"type": "string"},
          "status": {"enum": ["candidate_crop", "draft", "validated"]}
        }
      }
    }
  }
}
