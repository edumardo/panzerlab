    {"id": "d65250a-p036-para01", "text": {"de": {"plain": "Schwingungsdämpferbolzen durch Herausdrehen der Spindel herausziehen. Mutter wird mit Schraubenschlüssel SW 30 angezogen.", "runs": [{"text": "Schwingungsdämpferbolzen durch Herausdrehen der Spindel herausziehen. Mutter wird mit Schraubenschlüssel SW 30 angezogen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
