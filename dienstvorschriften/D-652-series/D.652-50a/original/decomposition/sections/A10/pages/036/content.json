    {"id": "d65250a-p036-para03", "text": {"de": {"plain": "Den Schwingarm mit Winde anheben.", "runs": [{"text": "Den Schwingarm mit Winde anheben.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p036-para04", "text": {"de": {"plain": "Beachten: Damit das Achsstummelgewinde nicht zerstört wird, muß die Kronenmutter aufgeschraubt werden.", "runs": [{"text": "Beachten:", "bold": true}, {"text": " Damit das Achsstummelgewinde nicht zerstört wird, muß die Kronenmutter aufgeschraubt werden.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p036-para05", "text": {"de": {"plain": "Holzklotz entfernen.", "runs": [{"text": "Holzklotz entfernen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
