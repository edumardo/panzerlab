    {"id": "d65250a-p034-para01", "text": {"de": {"plain": "Laufrolle nach Abschn. 3, S. 10, ausbauen.", "runs": [{"text": "Laufrolle nach Abschn. 3, S. 10, ausbauen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
