    {"id": "d65250a-p034-para04", "text": {"de": {"plain": "Blechsicherungen der Befestigungsschrauben geradebiegen.", "runs": [{"text": "Blechsicherungen der Befestigungsschrauben geradebiegen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
