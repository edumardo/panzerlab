    {"id": "d65250a-p007-para01", "text": {"de": {"plain": "Öffnen der Kette nach Abschnitt 1, S. 5.", "runs": [{"text": "Öffnen der Kette nach Abschnitt 1, S. 5.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para02", "text": {"de": {"plain": "Das einzubauende Kettenglied an das auf dem Boden liegende Kettenende legen.", "runs": [{"text": "Das einzubauende Kettenglied an das auf dem Boden liegende Kettenende legen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para03", "text": {"de": {"plain": "Den einen Kettenbolzen am Boden einschlagen.", "runs": [{"text": "Den einen Kettenbolzen am Boden einschlagen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para04", "text": {"de": {"plain": "Das freie Kettenende gegen das Triebrad legen.", "runs": [{"text": "Das freie Kettenende gegen das Triebrad legen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para05", "text": {"de": {"plain": "Den Kettenschließer ansetzen.", "runs": [{"text": "Den Kettenschließer ansetzen.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para06", "text": {"de": {"plain": "Das untere Kettenende mit Brechstange anheben.", "runs": [{"text": "Das untere Kettenende mit Brechstange anheben.", "bold": false}]}, "en-GB": null, "es-ES": null}},
    {"id": "d65250a-p007-para07", "text": {"de": {"plain": "Den zweiten Kettenbolzen von innen nach außen einschlagen.", "runs": [{"text": "Den zweiten Kettenbolzen von innen nach außen einschlagen.", "bold": false}]}, "en-GB": null, "es-ES": null}}
