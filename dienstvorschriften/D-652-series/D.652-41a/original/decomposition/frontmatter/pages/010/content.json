    {
      "id": "d65241a-page-010-para01",
      "text": {
        "de": {
          "plain": "Zur richtigen Behandlung des Sturmgeschützes sowie zum schnelleren Feststellen und Beseitigen von Störungen ist genaue Kenntnis der einzelnen Teile und deren Zusammenwirken erforderlich.",
          "runs": [
            {
              "text": "Zur richtigen Behandlung des Sturmgeschützes sowie zum schnelleren Feststellen und Beseitigen von Störungen ist genaue Kenntnis der einzelnen Teile und deren Zusammenwirken erforderlich.",
              "bold": false
            }
          ]
        },
        "en-GB": {
          "plain": "For the correct handling of the assault gun, and for the faster detection and elimination of faults, exact knowledge of the individual parts and their interaction is required.",
          "runs": [
            {
              "text": "For the correct handling of the assault gun, and for the faster detection and elimination of faults, exact knowledge of the individual parts and their interaction is required.",
              "bold": false
            }
          ]
        },
        "es-ES": {
          "plain": "Para el manejo correcto del cañón de asalto, así como para localizar y subsanar averías con mayor rapidez, se requiere un conocimiento exacto de las piezas individuales y de su funcionamiento conjunto.",
          "runs": [
            {
              "text": "Para el manejo correcto del cañón de asalto, así como para localizar y subsanar averías con mayor rapidez, se requiere un conocimiento exacto de las piezas individuales y de su funcionamiento conjunto.",
              "bold": false
            }
          ]
        }
      }
    },
    {
      "id": "d65241a-page-010-para02",
      "text": {
        "de": {
          "plain": "Nur sorgsames Behandeln und richtige Pflege des Gerätes verbürgen gute Leistungen und schützen vor frühzeitigem Unbrauchbarwerden.",
          "runs": [
            {
              "text": "Nur sorgsames Behandeln und richtige Pflege des Gerätes verbürgen gute Leistungen und schützen vor frühzeitigem Unbrauchbarwerden.",
              "bold": false
            }
          ]
        },
        "en-GB": {
          "plain": "Only careful handling and correct maintenance of the equipment guarantee good performance and protect against premature deterioration (becoming unserviceable).",
          "runs": [
            {
              "text": "Only careful handling and correct maintenance of the equipment guarantee good performance and protect against premature deterioration (becoming unserviceable).",
              "bold": false
            }
          ]
        },
        "es-ES": {
          "plain": "Solo un trato cuidadoso y un mantenimiento correcto del material garantizan un buen rendimiento y lo protegen de quedar inservible prematuramente.",
          "runs": [
            {
              "text": "Solo un trato cuidadoso y un mantenimiento correcto del material garantizan un buen rendimiento y lo protegen de quedar inservible prematuramente.",
              "bold": false
