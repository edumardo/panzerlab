    },
    {
      "id": "d65241a-page-010-para03",
      "text": {
        "de": {
          "plain": "Besondere Vorkommnisse, die die Gebrauchsfähigkeit des Gerätes beeinträchtigen, sind sofort auf dem vorgeschriebenen Wege zu melden.",
          "runs": [
            {
              "text": "Besondere Vorkommnisse, die die Gebrauchsfähigkeit des Gerätes beeinträchtigen, sind sofort auf dem vorgeschriebenen Wege zu melden.",
              "bold": false
            }
          ]
        },
        "en-GB": {
          "plain": "Special occurrences that impair the serviceability of the equipment are to be reported immediately through the prescribed channel.",
          "runs": [
